      "boundElements": null,
      "updated": 1778764131669,
      "link": null,
      "locked": false,
      "text": "Idea gallery screen : \nThis screen is similar to Instagram mian screen\n but not the social aspect that \neveryone post this is basically showing the shops products and teh shop \npost basically the thing they have with a name which will be used as the \nacount name instagram so basically at the top a descipring and people can \nlike it which addes it to their favorite by double tap like insta. They can make it \nfull screen so similar to a story where it takes your whole screen \nadd a transparent button on the side of the inage two arrows diagnolly pointly away icone \nor when trying to zoom in make it do that.  users can also filter by the tags at the top or \naddition filtering such as price by using the filter\nbutton and that only show them post regarding that topic ",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Idea gallery screen : \nThis screen is similar to Instagram mian screen\n but not the social aspect that \neveryone post this is basically showing the shops products and teh shop \npost basically the thing they have with a name which will be used as the \nacount name instagram so basically at the top a descipring and people can \nlike it which addes it to their favorite by double tap like insta. They can make it \nfull screen so similar to a story where it takes your whole screen \nadd a transparent button on the side of the inage two arrows diagnolly pointly away icone \nor when trying to zoom in make it do that.  users can also filter by the tags at the top or \naddition filtering such as price by using the filter\nbutton and that only show them post regarding that topic ",
      "autoResize": true,
      "lineHeight": 1.25
    },
